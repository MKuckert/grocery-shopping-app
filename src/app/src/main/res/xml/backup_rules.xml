<?xml version="1.0" encoding="utf-8"?>
<!--
   Backup rules for Grocery Shopping App.
   See https://developer.android.com/guide/topics/data/autobackup for details.
   Note: This file is ignored for devices older than API 31
   See https://developer.android.com/about/versions/12/backup-restore
-->
<full-backup-content>
    <!-- Exclude shared preferences: contains auth tokens (device-specific) -->
    <exclude domain="sharedpref" path="."/>
    
    <!-- Exclude databases: PowerSync local SQLite DB re-syncs from server on restore -->
    <exclude domain="database" path="."/>
</full-backup-content>
