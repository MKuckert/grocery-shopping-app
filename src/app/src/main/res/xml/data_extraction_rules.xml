<?xml version="1.0" encoding="utf-8"?>
<!--
   Data extraction rules for Grocery Shopping App.
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes for details.
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude shared preferences: contains auth tokens (device-specific) -->
        <exclude domain="sharedpref" path="."/>
        
        <!-- Exclude databases: PowerSync local SQLite DB re-syncs from server on restore -->
        <exclude domain="database" path="."/>
    </cloud-backup>
</data-extraction-rules>
