{
  "$schema": "https://opencode.ai/config.json",
  "model": "manifest/medium",
  "small_model": "manifest/small",
  "plugin": ["spotme"],
  "agent": {
    "build": {
      "disable": true,
      "mode": "primary",
    },
    "plan": {
      "disable": true,
      "mode": "primary",
    },
    "general": {
      "disable": true,
      "mode": "subagent",
    },
    "explore": {
      "disable": true,
      "mode": "subagent",
    },

    // System agents
    "compaction": {
      "mode": "primary",
      "hidden": true,
    },
    "title": {
      "mode": "primary",
      "hidden": true,
      "model": "manifest/mini",
    },
    "summary": {
      "mode": "primary",
      "hidden": true,
      "model": "manifest/small",
    },
  },
  "mcp": {
    "android": {
      "type": "remote",
      "enabled": true,
      "url": "http://localhost:12001",
    },
    "web": {
      "type": "remote",
      "enabled": true,
      "url": "http://localhost:12002/mcp",
    },
    "supabase": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.supabase.com/mcp?project_ref=sajpprxmybjoozlgqdme&features=docs%2Cdatabase%2Cdebugging%2Cdevelopment%2Cstorage",
    },
    "powersync": {
      "type": "remote",
      "enabled": true,
      "url": "https://docs.powersync.com/mcp",
    },
  },
  "permission": {
    "webfetch": "deny",
    "websearch": "deny",
    "supabase_*": "deny",
    "powersync_*": "deny",
  },
  "disabled_providers": [
    "opencode",
    "openai",
    "xai",
    "anthropic",
    "groq",
    "amazon-bedrock",
    "openrouter",
    "github-copilot",
    "google",
  ],
  "provider": {
    "manifest": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Manifest",
      "options": {
        "baseURL": "http://localhost:11438/v1",
        "apiKey": "mnfst_LWrVcNQ-QbyLAlKphpqlR9u6D-DvCrjSAMAry02TGO8",
      },
      "models": {
        "mini": {
          "name": "Mini (apple-on-device)",
          "headers": {
            "X-Manifest-Tier": "mini",
          },
          "limit": { "context": 2048, "input": 1024, "output": 1024 },
        },
        "small": {
          "name": "Small (omlx, GPT-5-mini)",
          "headers": {
            "X-Manifest-Tier": "small",
          },
        },
        "medium": {
          "name": "Medium (Haiku, GPT-5.4-mini)",
          "headers": {
            "X-Manifest-Tier": "medium",
          },
        },
        "medium-alt": {
          "name": "Medium Alt (GPT-5.4-mini, Haiku)",
          "headers": {
            "X-Manifest-Tier": "medium-alt",
          },
        },
        "complex": {
          "name": "Complex (Sonnet, Gemini Pro, GPT-5.3-Codex)",
          "headers": {
            "X-Manifest-Tier": "complex",
          },
        },
        "ultra": {
          "name": "Ultra (Opus, GPT-5.4)",
          "headers": {
            "X-Manifest-Tier": "ultra",
          },
        },
      },
    },
  },
  "formatter": true,
  "compaction": {
    "auto": true,
    "prune": true,
  },
  // Disables the snapshot feature to roll back agent changes as I'm not using it anyway
  "snapshot": false,
  "experimental": {
    "quotaToast": {
      "enableToast": false,
    },
    "batch_tool": true,
    "disable_paste_summary": true,
    "mcp_timeout": 600000,
  },
}
